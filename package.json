{
  "name": "n8n-nodes-zoho-assist",
  "version": "4.0.3",
  "description": "Zoho Assist integration for n8n with recordings download and Backblaze B2 pipeline support",
  "license": "MIT",
  "author": {
    "name": "Prince Vishwakarma",
    "email": "princevworld@gmail.com",
    "url": "https://github.com/princevish"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "n8n-nodes",
    "zoho",
    "zoho assist",
    "remote support",
    "automation",
    "recording download"
  ],
  "scripts": {
    "build": "tsc && node -e \"const fs = require('fs'); const path = 'dist/src/ZohoAssist'; if (!fs.existsSync(path)) fs.mkdirSync(path, { recursive: true }); fs.copyFileSync('src/ZohoAssist/zohoAssist.svg', path + '/zohoAssist.svg');\"",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "release": "n8n-node release"
  },
  "devDependencies": {
    "@n8n/eslint-plugin-community-nodes": "^0.10.0",
    "@n8n/node-cli": "^0.23.0",
    "n8n-workflow": "*",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "nodes": [
      "dist/src/ZohoAssist/ZohoAssist.node.js"
    ],
    "credentials": [
      "dist/src/credentials/ZohoAssistOAuth2.credentials.js"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/princevish/n8n-nodes-zoho-assist.git"
  },
  "bugs": {
    "url": "https://github.com/princevish/n8n-nodes-zoho-assist/issues"
  },
  "homepage": "https://github.com/princevish/n8n-nodes-zoho-assist#readme"
}
